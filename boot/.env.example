# API Admin
API_PORT=7070
JWT_SECRET=change_me_to_a_long_random_secret
SUPER_ADMIN_EMAIL=admin@boot.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# URL officielle a surveiller (ex: page de connexion/rendez-vous BLS)
TARGET_URL=https://algeria.blsspainglobal.com/DZA/account/login

# Frequence de verification en secondes (recommande: 60 a 180)
CHECK_INTERVAL_SECONDS=90

# Texte indicateur quand des rendez-vous peuvent etre disponibles.
# Exemple: rendez-vous, appointment available, disponible
AVAILABILITY_REGEX=(rendez\-vous|appointment\s+available|disponible)

# Texte indicateur d'absence de disponibilite (utilise pour filtrer les faux positifs)
NO_SLOT_REGEX=(aucun\s+rendez\-vous\s+disponible|no\s+appointments?\s+available|complet)

# Telegram
# TELEGRAM_CHAT_ID: fallback si aucun client actif n'est configure
# TELEGRAM_ADMIN_CHAT_ID: votre chat id admin pour supervision
ENABLE_TELEGRAM_BOT=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# Activer appel de reveil via Twilio (true/false)
ENABLE_CALL=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
USER_PHONE_NUMBER=

# Message vocal Twilio (URL TwiML publique, optionnel)
TWILIO_TWIML_URL=https://handler.twilio.com/twiml/EHXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Limite anti-spam: ne pas renvoyer la meme alerte avant X minutes
ALERT_COOLDOWN_MINUTES=20

# Timeout HTTP en ms
REQUEST_TIMEOUT_MS=15000
